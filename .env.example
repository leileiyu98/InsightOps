# Local development examples only. Do not reuse these values in shared or production systems.
APP_NAME=InsightOps
APP_ENV=local
APP_DEBUG=false

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=insightops
DATABASE_USER=insightops_dev
DATABASE_PASSWORD=local_dev_password_change_me

# Dedicated SELECT-only identity used exclusively by the evaluation harness.
READONLY_DATABASE_HOST=127.0.0.1
READONLY_DATABASE_PORT=3306
READONLY_DATABASE_NAME=insightops
READONLY_DATABASE_USER=insightops_readonly
READONLY_DATABASE_PASSWORD=local_readonly_password_change_me

# Used only by the MySQL container during local initialization.
MYSQL_ROOT_PASSWORD=local_root_password_change_me

# Text2SQL defaults to the deterministic offline provider. Set QUERY_PROVIDER=openai
# and provide a real key only for a manual external-provider smoke test.
QUERY_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_TIMEOUT_SECONDS=30
